1998 Democratic     \n6 AK    1999 Democratic     "}},"1":{"data":{"iframe":"3fe4f0f6756bc21f214dc2b2ce2b088dd4c7fa96","text/latex":"\\begin{enumerate*}\n\\item 'Democrat'\n\\item 'Republican'\n\\item 'Independent'\n\\item 'Minnesota Independence Party'\n\\item 'Democratic-Farmer-Labor'\n\\end{enumerate*}\n","text/markdown":"1. 'Democrat'\n2. 'Republican'\n3. 'Independent'\n4. 'Minnesota Independence Party'\n5. 'Democratic-Farmer-Labor'\n\n\n","text/plain":"[1] \"Democrat\"                     \"Republican\"                  \n[3] \"Independent\"                  \"Minnesota Independence Party\"\n[5] \"Democratic-Farmer-Labor\"     "}}},"pos":5,"start":1769200369771,"state":"done","type":"cell"}
